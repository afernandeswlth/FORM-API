# ── SMTP Configuration ────────────────────────────────────────────────────
# Copy this file to .env and fill in your credentials.

# Microsoft 365 (most common for WLTH)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=forms@wlth.com
SMTP_PASS=your-password-here
FROM_EMAIL=forms@wlth.com
FROM_NAME=WLTH Forms

# ── Google Workspace alternative ─────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=forms@wlth.com
# SMTP_PASS=your-app-password   # Use an App Password, not your account password
# FROM_EMAIL=forms@wlth.com
# FROM_NAME=WLTH Forms
