{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": [
          "main.py",
          "requirements.txt",
          "FormHub/**",
          "LinkedAccountAPI/**",
          "DirectDebitAPI/**",
          "RepaymentChangeAPI/**",
          "OpenOffsetAPI/**",
          "ProductSwitchAPI/**",
          "RedrawAPI/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/index.py" }
  ]
}
